@online{kimMultitaskRealrobotData2024,
  title = {Multi-Task Real-Robot Data with Gaze Attention for Dual-Arm Fine Manipulation},
  author = {Kim, Heecheol and Ohmura, Yoshiyuki and Kuniyoshi, Yasuo},
  date = {2024-03-19},
  eprint = {2401.07603},
  eprinttype = {arXiv},
