@article{maunsellVisualResponseLatencies1999,
  title = {Visual Response Latencies of Magnocellular and Parvocellular {{LGN}} Neurons in Macaque Monkeys},
  author = {Maunsell, John H. R. and Ghose, Geoffrey M. and Assad, John A. and McADAMS, Carrie J. and Boudreau, Christen Elizabeth and Noerager, Brett D.},
  date = {1999-01},
