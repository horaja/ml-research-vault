  shorttitle = {Unsupervised {{Structure Learning}}},
  booktitle = {Computer {{Vision}} – {{ECCV}} 2008},
  author = {Zhu, Long (Leo) and Lin, Chenxi and Huang, Haoda and Chen, Yuanhao and Yuille, Alan},
