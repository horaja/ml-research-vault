}

@article{panDepthGuidedVisionTransformer2024,
  title = {Depth-{{Guided Vision Transformer With Normalizing Flows}} for {{Monocular 3D Object Detection}}},
  author = {Pan, Cong and Peng, Junran and Zhang, Zhaoxiang},
  date = {2024-03},
  journaltitle = {IEEE/CAA Journal of Automatica Sinica},
