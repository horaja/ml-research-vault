  shorttitle = {Toward a Computational Theory of Manifold Untangling},
  author = {Li, Xin and Wang, Shuo},
  date = {2023-05-31},
  journaltitle = {Frontiers in Computational Neuroscience},
  shortjournal = {Front. Comput. Neurosci.},
  volume = {17},
