@online{qiaoVThinkerInteractiveThinking2025,
  title = {V-{{Thinker}}: {{Interactive Thinking}} with {{Images}}},
  shorttitle = {V-{{Thinker}}},
  author = {Qiao, Runqi and Tan, Qiuna and Yang, Minghan and Dong, Guanting and Yang, Peiqing and Lang, Shiqiang and Wan, Enhui and Wang, Xiaowan and Xu, Yida and Yang, Lan and Sun, Chong and Li, Chen and Zhang, Honggang},
  date = {2025-11-06},
  eprint = {2511.04460},
